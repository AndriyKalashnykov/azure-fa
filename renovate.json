{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    ":semanticCommitType(chore)",
    "config:best-practices"
  ],
  "baseBranches": [
    "main"
  ],
  "labels": [
    "dependencies"
  ],
  "automerge": true,
  "automergeType": "branch",
  "platformAutomerge": true,
  "ignoreTests": false,
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "automerge": true,
    "minimumReleaseAge": "0 days"
  },
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "matchPackageNames": [
        "node"
      ],
      "major": {
        "enabled": true
      },
      "separateMultipleMajor": true,
      "allowedVersions": "^20 || ^22",
      "automerge": true
    },
    {
      "matchDepTypes": [
        "dependencies"
      ],
      "groupName": "Dependencies",
      "automerge": true
    },
    {
      "matchDepTypes": [
        "devDependencies"
      ],
      "groupName": "Dev Dependencies",
      "automerge": true
    },
    {
      "groupName": "app",
      "groupSlug": "function-app-dependencies",
      "matchFiles": [
        "package.json"
      ],
      "labels": [
        "root",
        "Renovate"
      ],
      "automerge": true
    },
    {
      "groupName": "infrastructure",
      "groupSlug": "terraform-module-dependencies",
      "matchPaths": [
        "infra/**"
      ],
      "labels": [
        "module",
        "Renovate"
      ],
      "automerge": true
    },
    {
      "groupName": "Configuration",
      "groupSlug": "config-dependencies",
      "matchPaths": [
        "config/**"
      ],
      "labels": [
        "terraform",
        "Renovate"
      ],
      "automerge": true
    },
    {
      "description": "Wait 3 days before automerging major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Group GitHub Actions into one PR",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Group devDependencies non-major updates",
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "dev-dependencies",
      "automerge": true
    },
    {
      "description": "Group type definitions",
      "matchPackageNames": [
        "/^@types\\\\//"
      ],
      "groupName": "type-definitions",
      "automerge": true
    }
  ],
  "prHourlyLimit": 0,
  "commitBody": "Signed-off-by: Renovate Bot <bot@renovateapp.com>",
  "prConcurrentLimit": 50,
  "commitMessageAction": "update",
  "automergeStrategy": "squash",
  "commitMessagePrefix": "chore(all): ",
  "npm": {
    "minimumReleaseAge": "3 days"
  }
}
